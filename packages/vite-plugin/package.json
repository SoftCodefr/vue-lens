{
  "name": "@softcodefr/vue-lens",
  "version": "0.0.14",
  "description": "A Vite plugin for Vue.js debugging and inspection",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "vue",
    "vite",
    "vite-plugin",
    "devtools",
    "debugging",
    "inspector",
    "pinia",
    "vue-router",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftCodefr/vue-lens.git",
    "directory": "packages/vite-plugin"
  },
  "homepage": "https://github.com/SoftCodefr/vue-lens#readme",
  "bugs": {
    "url": "https://github.com/SoftCodefr/vue-lens/issues"
  },
  "license": "MIT",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@softcodefr/vue-lens-core": "workspace:*"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.6",
    "@types/node": "^25.6.0",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  }
}
