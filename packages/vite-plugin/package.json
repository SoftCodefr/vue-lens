{
  "name": "@softcodefr/vue-lens-vite-plugin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/panel.ts src/router.ts --format esm,cjs --dts --shims --no-splitting",
    "dev": "tsup src/index.ts src/panel.ts src/router.ts --format esm,cjs --dts --shims --no-splitting --watch"
  },
  "dependencies": {
    "@softcodefr/vue-lens-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  },
  "peerDependencies": {
    "vite": "^5.0.0"
  }
}
