{
  "name": "@softcodefr/vue-lens-core",
  "version": "0.0.8",
  "description": "Core utilities for Vue Lens debugging tools",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "vue",
    "vite",
    "devtools",
    "debugging",
    "inspector"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftCodefr/vue-lens.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/SoftCodefr/vue-lens#readme",
  "bugs": {
    "url": "https://github.com/SoftCodefr/vue-lens/issues"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.6",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}